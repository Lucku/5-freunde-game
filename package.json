{
  "name": "5-freunde-arena",
  "version": "1.2.0-dev",
  "productName": "5 Freunde Elemental Arena",
  "description": "Roguelite Fantasy Arena Game",
  "main": "index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dev": "VITE_DEV=1 vite",
    "dev:electron": "VITE_DEV=1 concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.mjs",
    "lint:fix": "eslint . --ext .js,.mjs --fix",
    "test": "vitest run --passWithNoTests && node server/simulation/parityTest.js",
    "test:watch": "vitest"
  },
  "author": "Lucas Kuhring",
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron/fuses": "^1.8.0",
    "concurrently": "^9.0.1",
    "electron": "^39.2.6",
    "esbuild": "^0.28.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "vite": "^8.0.0",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.28.0",
    "electron-squirrel-startup": "^1.0.1"
  }
}
