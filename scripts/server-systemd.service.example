# /etc/systemd/system/5freunde-server.service
#
# Sample systemd unit for the 5 Freunde game server. Copy this file to the
# path above, edit USER/WorkingDirectory/EnvironmentFile, then:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now 5freunde-server.service
#
# Binding to a privileged port (e.g. 443) without running as root requires
# the CAP_NET_BIND_SERVICE capability on the node binary, or use a reverse
# proxy (recommended) on an unprivileged port.
#   sudo setcap 'cap_net_bind_service=+ep' /usr/bin/node

[Unit]
Description=5 Freunde game server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=5freunde
Group=5freunde
WorkingDirectory=/opt/5freunde
EnvironmentFile=/opt/5freunde/server/.env
ExecStart=/usr/bin/node /opt/5freunde/server/server.js
Restart=on-failure
RestartSec=5

# Hardening — drop capabilities, isolate the file-system view.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
ReadWritePaths=/opt/5freunde/server/data
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
