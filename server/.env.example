# 5 Freunde server configuration template.
# Copy to `server/.env` and edit. Loaded automatically by `server/server.js`
# (via `require('dotenv').config()`).

# ── Networking ───────────────────────────────────────────────────────────────
# Public hostname used by clients. Drives cert issuance + origin allowlist.
SERVER_HOST=your.host.example.com

# Listen port. 443 for native TLS in Node; 3001 if behind a reverse proxy.
PORT=3001

# Comma-separated list of origins allowed to upgrade WebSocket connections.
# Must include the exact origin the browser sends (no trailing slash). Use the
# https form when TLS is on. Empty = wildcard (dev only).
ALLOWED_WS_ORIGINS=https://your.host.example.com

# ── TLS (set these to enable https + wss) ────────────────────────────────────
# Absolute paths to PEM files. Leave unset for plain http + ws (dev only).
# Populated automatically by scripts/server-tls-letsencrypt.sh or
# scripts/server-tls-selfsigned.sh.
TLS_CERT_PATH=
TLS_KEY_PATH=
# Optional intermediate-chain bundle if your CA delivers it separately.
TLS_CA_PATH=

# ── Secrets ──────────────────────────────────────────────────────────────────
# Replace both before going to production. JWT_SECRET signs auth tokens;
# rotating it invalidates every existing session.
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password
